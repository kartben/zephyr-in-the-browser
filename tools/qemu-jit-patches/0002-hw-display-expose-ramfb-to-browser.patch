diff --git a/hw/display/ramfb.c b/hw/display/ramfb.c
index 8c0f907..ac023c5 100644
--- a/hw/display/ramfb.c
+++ b/hw/display/ramfb.c
@@ -19,6 +19,12 @@
 #include "ui/console.h"
 #include "system/reset.h"
 
+#ifdef __EMSCRIPTEN__
+#include <emscripten.h>
+#else
+#define EMSCRIPTEN_KEEPALIVE
+#endif
+
 struct QEMU_PACKED RAMFBCfg {
     uint64_t addr;
     uint32_t fourcc;
@@ -33,9 +39,55 @@ typedef struct RAMFBCfg RAMFBCfg;
 struct RAMFBState {
     DisplaySurface *ds;
     uint32_t width, height;
+    uint32_t stride;
+    uint8_t *data;
     struct RAMFBCfg cfg;
 };
 
+/*
+ * Browser display bridge.  qemu-wasm has no graphical display backend, but
+ * ramfb already maps the guest framebuffer into QEMU's address space.  Keep
+ * that address and expose it to JavaScript so the browser can paint the pixels
+ * onto a canvas without adding SDL to QEMU itself.
+ */
+static RAMFBState *browser_ramfb;
+
+uint32_t qemu_browser_ramfb_get_width(void);
+uint32_t qemu_browser_ramfb_get_height(void);
+uint32_t qemu_browser_ramfb_get_stride(void);
+uintptr_t qemu_browser_ramfb_get_data(void);
+uint32_t qemu_browser_ramfb_get_fourcc(void);
+
+EMSCRIPTEN_KEEPALIVE
+uint32_t qemu_browser_ramfb_get_width(void)
+{
+    return browser_ramfb ? browser_ramfb->width : 0;
+}
+
+EMSCRIPTEN_KEEPALIVE
+uint32_t qemu_browser_ramfb_get_height(void)
+{
+    return browser_ramfb ? browser_ramfb->height : 0;
+}
+
+EMSCRIPTEN_KEEPALIVE
+uint32_t qemu_browser_ramfb_get_stride(void)
+{
+    return browser_ramfb ? browser_ramfb->stride : 0;
+}
+
+EMSCRIPTEN_KEEPALIVE
+uintptr_t qemu_browser_ramfb_get_data(void)
+{
+    return browser_ramfb ? (uintptr_t)browser_ramfb->data : 0;
+}
+
+EMSCRIPTEN_KEEPALIVE
+uint32_t qemu_browser_ramfb_get_fourcc(void)
+{
+    return browser_ramfb ? be32_to_cpu(browser_ramfb->cfg.fourcc) : 0;
+}
+
 static void ramfb_unmap_display_surface(pixman_image_t *image, void *unused)
 {
     void *data = pixman_image_get_data(image);
@@ -99,6 +151,8 @@ static void ramfb_fw_cfg_write(void *dev, off_t offset, size_t len)
 
     s->width = width;
     s->height = height;
+    s->stride = pixman_image_get_stride(surface->image);
+    s->data = (uint8_t *)pixman_image_get_data(surface->image);
     qemu_free_displaysurface(s->ds);
     s->ds = surface;
 }
@@ -146,6 +200,7 @@ RAMFBState *ramfb_setup(Error **errp)
     }
 
     s = g_new0(RAMFBState, 1);
