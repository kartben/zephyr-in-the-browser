+/*
+ * Browser-fed pointer and keyboard input.
+ *
+ * SPDX-License-Identifier: GPL-2.0-or-later
+ */
+
+#ifndef HW_MISC_QEMU_BROWSER_INPUT_H
+#define HW_MISC_QEMU_BROWSER_INPUT_H
+
+/*
+ * Arms the drain timer. The browser fills a lock-free event ring and the
+ * timer replays it into QEMU's input core on the QEMU thread, where the
+ * virtio-input device models can be touched safely.
+ */
+void qemu_browser_input_init(void);
+
+#endif
