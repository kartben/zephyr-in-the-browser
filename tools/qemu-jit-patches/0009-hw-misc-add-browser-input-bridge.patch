diff --git a/hw/misc/qemu-browser-input.c b/hw/misc/qemu-browser-input.c
new file mode 100644
index 0000000..d741802
--- /dev/null
+++ b/hw/misc/qemu-browser-input.c
@@ -0,0 +1,201 @@
+/*
+ * Browser-fed pointer and keyboard input.
+ *
+ * QEMU's input core is normally driven by a UI backend -- SDL, GTK, VNC --
+ * which turns host events into qemu_input_*() calls. qemu-wasm is configured
+ * without any of them, so the virtio-input device models are present but have
+ * nothing feeding them. This is that missing frontend, and the counterpart to
+ * the ramfb export: pixels leave through hw/display/ramfb.c, pointer events
+ * come back in here.
+ *
+ * Page JavaScript appends events to a single-producer/single-consumer ring and
+ * a virtual-clock timer replays them under the BQL, the same split the browser
+ * GNSS chardev and the browser netdev use -- the JS-visible entry points touch
+ * nothing but ring memory, and every call into QEMU proper happens on the QEMU
+ * thread.
+ *
+ * A record is four 32-bit words, so the browser can address the ring as an
+ * Int32Array without any packing:
+ *
+ *     u32 kind | u32 code | i32 value | u32 reserved
+ *
+ * The write index is published once per *packet* -- a group of records ending
+ * in SYNC -- rather than once per record, so a drain never observes half a
+ * packet and the guest never sees pointer coordinates without the SYNC that
+ * commits them.
+ *
+ * Nothing here is browser-specific: the entry points are ordinary C, so a
+ * native QEMU build can drive the same ring from a test harness.
+ *
+ * SPDX-License-Identifier: GPL-2.0-or-later
+ */
+
+#include "qemu/osdep.h"
+#include "qemu/atomic.h"
+#include "qemu/timer.h"
+#include "ui/input.h"
+#include "hw/misc/qemu-browser-input.h"
+
+#ifdef __EMSCRIPTEN__
+#include <emscripten.h>
+#else
+#define EMSCRIPTEN_KEEPALIVE
+#endif
+
+#define BROWSER_INPUT_RING_EVENTS 256                       /* power of two */
+#define BROWSER_INPUT_RING_MASK   (BROWSER_INPUT_RING_EVENTS - 1)
+#define BROWSER_INPUT_POLL_MS     10
+
+/* Record kinds. src/hostInput.ts mirrors these values. */
+enum {
+    BROWSER_INPUT_SYNC = 0,  /* end of packet; code and value unused         */
+    BROWSER_INPUT_ABS  = 1,  /* code: InputAxis, value: 0..0x7fff            */
+    BROWSER_INPUT_BTN  = 2,  /* code: InputButton, value: 0 up / 1 down      */
+    BROWSER_INPUT_REL  = 3,  /* code: InputAxis, value: signed delta         */
+    BROWSER_INPUT_KEY  = 4,  /* code: Linux evdev keycode, value: 0 up/1 down */
+};
+
+typedef struct BrowserInputEvent {
+    uint32_t kind;
+    uint32_t code;
+    int32_t  value;
+    uint32_t reserved;
+} BrowserInputEvent;
+
+static BrowserInputEvent browser_input_ring[BROWSER_INPUT_RING_EVENTS];
+static uint32_t browser_input_wr;      /* free-running, written by the browser */
+static uint32_t browser_input_rd;      /* free-running, written by QEMU        */
+static QEMUTimer *browser_input_timer;
+
+/* --- entry points for the embedding host (Module._qemu_browser_input_*) --- */
+
+EMSCRIPTEN_KEEPALIVE
+uint32_t qemu_browser_input_ready(void)
+{
+    return browser_input_timer != NULL;
+}
+
+EMSCRIPTEN_KEEPALIVE
+uint32_t qemu_browser_input_ring_events(void)
+{
+    return BROWSER_INPUT_RING_EVENTS;
+}
+
+EMSCRIPTEN_KEEPALIVE
+uintptr_t qemu_browser_input_ring(void)
+{
+    return (uintptr_t)browser_input_ring;
+}
+
+EMSCRIPTEN_KEEPALIVE
+uint32_t qemu_browser_input_write_index(void)
+{
+    return qatomic_read(&browser_input_wr);
+}
+
+EMSCRIPTEN_KEEPALIVE
+uint32_t qemu_browser_input_read_index(void)
+{
+    return qatomic_read(&browser_input_rd);
+}
+
+EMSCRIPTEN_KEEPALIVE
+void qemu_browser_input_set_write_index(uint32_t value)
+{
+    qatomic_set(&browser_input_wr, value);
+}
+
+/* --- browser -> guest (QEMU thread, BQL held) ----------------------------- */
+
+static void browser_input_deliver(const BrowserInputEvent *evt)
+{
+    int qcode;
+
+    switch (evt->kind) {
+    case BROWSER_INPUT_SYNC:
+        qemu_input_event_sync();
+        break;
+
+    case BROWSER_INPUT_ABS:
+        if (evt->code >= INPUT_AXIS__MAX) {
+            return;
+        }
+        /*
+         * Already in QEMU's absolute range, so the scale is the identity: the
+         * browser is the only thing that knows the canvas geometry, and it has
+         * to map client coordinates onto the framebuffer anyway.
+         */
+        qemu_input_queue_abs(NULL, evt->code, evt->value,
+                             INPUT_EVENT_ABS_MIN, INPUT_EVENT_ABS_MAX);
+        break;
+
+    case BROWSER_INPUT_REL:
+        if (evt->code >= INPUT_AXIS__MAX) {
+            return;
+        }
+        qemu_input_queue_rel(NULL, evt->code, evt->value);
+        break;
+
+    case BROWSER_INPUT_BTN:
+        if (evt->code >= INPUT_BUTTON__MAX) {
+            return;
+        }
+        qemu_input_queue_btn(NULL, evt->code, evt->value != 0);
+        break;
+
+    case BROWSER_INPUT_KEY:
+        /*
+         * Linux evdev keycodes on the wire rather than QKeyCode: the browser
+         * would otherwise have to hardcode a QAPI enum whose numbering is a
+         * build artefact of the QEMU it happens to be talking to.
+         */
+        qcode = qemu_input_linux_to_qcode(evt->code);
+        if (qcode <= Q_KEY_CODE_UNMAPPED) {
+            return;
+        }
+        qemu_input_event_send_key_qcode(NULL, qcode, evt->value != 0);
+        break;
+
+    default:
+        break;
+    }
+}
+
+static void browser_input_drain(void *opaque)
+{
+    uint32_t wr = qatomic_read(&browser_input_wr);
+    uint32_t rd = browser_input_rd;
+
+    /*
+     * A well-behaved producer stops writing when the ring is full, so this
+     * only bites if one runs away. Skip to the newest full ring rather than
+     * replaying records already overwritten: for pointer motion the freshest
+     * position is the only one that matters anyway.
+     */
+    if (wr - rd > BROWSER_INPUT_RING_EVENTS) {
+        rd = wr - BROWSER_INPUT_RING_EVENTS;
+    }
+
+    while (rd != wr) {
+        BrowserInputEvent evt = browser_input_ring[rd & BROWSER_INPUT_RING_MASK];
+
+        browser_input_deliver(&evt);
+        rd++;
+    }
+    qatomic_set(&browser_input_rd, rd);
+
+    timer_mod(browser_input_timer,
+              qemu_clock_get_ms(QEMU_CLOCK_VIRTUAL) + BROWSER_INPUT_POLL_MS);
+}
+
+void qemu_browser_input_init(void)
+{
+    if (browser_input_timer) {
+        return;
+    }
+
+    browser_input_timer = timer_new_ms(QEMU_CLOCK_VIRTUAL,
+                                       browser_input_drain, NULL);
+    timer_mod(browser_input_timer,
+              qemu_clock_get_ms(QEMU_CLOCK_VIRTUAL) + BROWSER_INPUT_POLL_MS);
+}
