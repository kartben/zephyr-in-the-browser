diff --git a/meson.build b/meson.build
index 50c774a..fdd9831 100644
--- a/meson.build
+++ b/meson.build
@@ -3384,8 +3384,11 @@ foreach target : target_dirs
 
   target_kconfig = []
   foreach sym: accelerators
-    # Disallow 64-bit on 32-bit emulation and virtualization
-    if host_long_bits < config_target['TARGET_LONG_BITS'].to_int()
+    # Native accelerators cannot run wider guests, but TCI represents guest
+    # values independently of host pointer width.  The latter is required for
+    # 64-bit guests on wasm32, where no native TCG backend exists.
+    if host_long_bits < config_target['TARGET_LONG_BITS'].to_int() and \
+       not get_option('tcg_interpreter')
       continue
     endif
     if sym == 'CONFIG_TCG' or target in accelerator_targets.get(sym, [])
