config QEMU_HOST_SENSOR
	bool "QEMU host-backed sensor"
	default y
	depends on DT_HAS_QEMU_HOST_SENSOR_ENABLED
	depends on SENSOR
	help
	  Sensor driver for the qemu-host-sensor MMIO device, whose sample
	  values are supplied by the QEMU host rather than by emulated
	  hardware. Under qemu-wasm that host is a browser, so the values can
	  come from Web sensor APIs.

config QEMU_HOST_GPIO
	bool "QEMU host-backed GPIO"
	default y
	depends on DT_HAS_QEMU_HOST_GPIO_ENABLED
	depends on GPIO
	help
	  GPIO controller driver for the qemu-host-gpio MMIO device, whose input
	  pins are driven by the QEMU host and whose output pins are observed by
	  it. Under qemu-wasm that host is a browser, so a page can raise buttons
	  on the inputs and light indicators from the outputs the guest drives.

config QEMU_HOST_AUDIO
	bool "QEMU host-backed audio out (I2S)"
	default y
	depends on DT_HAS_QEMU_HOST_AUDIO_ENABLED
	depends on I2S
	help
	  Transmit-only I2S driver for the qemu-host-audio MMIO device: a PCM
	  ring the guest fills and the QEMU host drains. Under qemu-wasm that
	  host is a browser, so anything an application plays through Zephyr's
	  I2S API comes out of the speakers via the Web Audio API.

config QEMU_HOST_AUDIO_SHELL
	bool "hostaudio shell commands"
	default y
	depends on QEMU_HOST_AUDIO && SHELL
	help
	  `hostaudio info|beep|melody` commands, driving the audio bridge
	  through the I2S API, so it is demoable from the stock shell sample
	  without writing an application.

config QEMU_HOST_MIC
	bool "QEMU host-backed microphone (DMIC)"
	default y
	depends on DT_HAS_QEMU_HOST_MIC_ENABLED
	depends on AUDIO_DMIC
	help
	  DMIC driver for the qemu-host-mic MMIO device: a PCM ring the QEMU
	  host fills and the guest drains. Under qemu-wasm that host is a
	  browser capturing getUserMedia audio, so Zephyr's DMIC API records
	  from the user's real microphone.
