/*
 * Copyright (c) 2026
 * SPDX-License-Identifier: Apache-2.0
 *
 * Browser bridge on the Cortex-A53 (virt) machine: the browser-fed GNSS UART
 * on virt's spare PL011 slot, a browser-sized ramfb, and the qemu,host-sensor
 * with the same accel0/temp0/... aliases the Cortex-M3 gets, so stock sensor
 * samples (and the LVGL accelerometer chart) build unmodified.
 *
 * The host sensor sits at 0x090c0000, the host audio out at 0x090d0000 and
 * the host microphone at 0x090e0000 — holes in virt's MMIO map between the
 * secure GPIO (0x090b0000) and the virtio region (0x0a000000), so they
 * cannot collide with anything the machine actually maps. Our patched
 * qemu-wasm virt machine instantiates the devices at these exact addresses;
 * see tools/qemu-jit-patches/0004-hw-misc-add-qemu-host-sensor.patch,
 * 0005-hw-misc-add-qemu-host-audio.patch and
 * 0006-hw-misc-add-qemu-host-mic.patch.
 *
 * Zephyr's stock Cortex-A53 ramfb is 1024x768. That is unnecessarily large for
 * the browser demo: every refresh is emulated by QEMU and uploaded as a browser
 * texture. 600x400 retains a useful 3:2 display while reducing the pixel count
 * by 69.5%.
 */

/ {
	aliases {
		gnss = &gnss;
		dmic0 = &host_mic;
		accel0 = &host_sensor;
		temp0 = &host_sensor;
		ambient-temp0 = &host_sensor;
		light0 = &host_sensor;
		humidity0 = &host_sensor;
		press0 = &host_sensor;
	};

	soc {
		uart1: uart@9040000 {
			compatible = "arm,pl011";
			reg = <0x0 0x09040000 0x0 0x1000>;
			interrupts = <GIC_SPI 8 IRQ_TYPE_LEVEL IRQ_DEFAULT_PRIORITY>;
			interrupt-names = "irq_0";
			clocks = <&uartclk>;
			current-speed = <9600>;
			status = "okay";

			gnss: gnss-nmea-generic {
				compatible = "gnss-nmea-generic";
			};
		};

		host_sensor: sensor@90c0000 {
			compatible = "qemu,host-sensor";
			reg = <0x0 0x090c0000 0x0 0x1000>;
			status = "okay";
		};

		host_audio: audio@90d0000 {
			compatible = "qemu,host-audio";
			reg = <0x0 0x090d0000 0x0 0x1000>;
			status = "okay";
		};

		host_mic: audio@90e0000 {
			compatible = "qemu,host-mic";
			reg = <0x0 0x090e0000 0x0 0x1000>;
			status = "okay";
		};
	};
};

&ramfb0 {
	width = <600>;
	height = <400>;
};

/*
 * Browser network bridge: virtio-net on the first virtio-mmio slot, which
 * QEMU populates with `-device virtio-net-device,bus=virtio-mmio-bus.0`
 * (0x0a000000, SPI 16). The MAC must stay in step with the `mac=` property
 * in src/boards.ts: QEMU's virtio-net model filters inbound unicast against
 * it, and Zephyr's driver takes its address from devicetree without ever
 * programming the device. Costs non-networking samples nothing — the driver
 * stack only builds behind NET_L2_ETHERNET.
 */
&virtio_mmio0 {
	status = "okay";

	virtio_net0: virtio-net {
		compatible = "virtio,net";
		local-mac-address = [02 00 00 00 00 01];
		status = "okay";
	};
};

/*
 * Silence the stock e1000 PCIe path: the promptless QEMU_CORTEX_A53_ETH_E1000
 * would otherwise select ETH_E1000 + PCIE (with a 2 GiB VM space) the moment
 * NETWORKING=y, fighting the virtio-net setup above.
 */
&eth0 {
	status = "disabled";
};
